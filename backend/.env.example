# =============================================================================
# Pingload Backend — Production Environment Template
# =============================================================================
# Copy to .env and fill every value before deploying.
# For local development with sandbox providers, use .env.development.example instead.
# Never commit a filled .env file.
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=5003
NODE_ENV=production

# Must be "production" when NODE_ENV=production (enforced at startup)
SERVICE_MODE=production

# MongoDB connection string (MongoDB Atlas or self-hosted replica set recommended)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pingload?retryWrites=true&w=majority

# Strong random string — generate with: openssl rand -base64 48
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=7d

# ── Paystack (LIVE) ───────────────────────────────────────────────────────────
# Dashboard: https://dashboard.paystack.com/#/settings/developer
# Use pk_live_* and sk_live_* keys only in production.
PAYSTACK_ENV=live
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Optional override (default: https://api.paystack.co)
# PAYSTACK_BASE_URL=https://api.paystack.co

# Webhook URL to register in Paystack dashboard:
#   https://pingload.top/api/webhooks/paystack
# Paystack signs webhooks with PAYSTACK_SECRET_KEY.

# ── VTpass (LIVE) ─────────────────────────────────────────────────────────────
# Dashboard: https://vtpass.com — use live API credentials
VTPASS_ENV=live
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=PK_
VTPASS_SECRET_KEY=SK
# Optional override (default live: https://vtpass.com/api)
# VTPASS_BASE_URL=https://vtpass.com/api

# ── Termii OTP ────────────────────────────────────────────────────────────────
# Dashboard: https://accounts.termii.com/
TERMII_API_KEY=
TERMII_SENDER_ID=Pingload
TERMII_BASE_URL=https://api.ng.termii.com/api
TERMII_EMAIL_CONFIGURATION_ID=
# Channel: auto | sms | whatsapp | email
TERMII_OTP_CHANNEL=auto

# ── URLs & CORS ───────────────────────────────────────────────────────────────
# Public API URL (mobile/admin apps call this + /api)
API_PUBLIC_URL=https://pingload.top

# Paystack redirect after checkout — deep link or web URL the app handles
# Example: pingload://wallet/verify  or  https://pingload.top/wallet/verify
FRONTEND_URL=pingload://wallet/verify

# Comma-separated allowed origins for CORS (admin dashboard URL, etc.)
CORS_ORIGIN=https://admin.pingload.top

# ── App settings ──────────────────────────────────────────────────────────────
REFERRAL_BONUS=100

# MUST be false in production (enforced at startup)
DEVELOPMENT_MODE=false

# Structured JSON logs for Paystack, VTpass, wallet operations
ENABLE_SERVICE_LOGS=true

# ── Admin bootstrap (first deploy only) ───────────────────────────────────────
# Used by seedAdmin to create the initial super-admin if none exists.
# Change password immediately after first login.
ADMIN_EMAIL=admin@pingload.top
ADMIN_PASSWORD=<strong-admin-password-min-12-chars>

# ── Public support & legal (returned via GET /api/services/app-config) ────────
APP_DOMAIN=pingload.top
PRIVACY_POLICY_URL=https://pingload.top/privacy
TERMS_URL=https://pingload.top/terms
SUPPORT_EMAIL=support@pingload.top
SUPPORT_WHATSAPP=2348000000000

# ── Firebase Cloud Messaging (push notifications) ─────────────────────────────
# Create a Firebase project and service account with Firebase Cloud Messaging enabled.
# Download service account JSON or set individual fields below.
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_CLIENT_EMAIL=<your-firebase-client-email>
# Private key from service account JSON — keep literal \n for line breaks
FIREBASE_PRIVATE_KEY=<your-firebase-private-key>
