# =============================================================================
# Pingload Backend — Local Development (Sandbox / Test Providers)
# =============================================================================
# Copy to .env for local development ONLY. Do not use in production.
# cp .env.development.example .env
# =============================================================================

PORT=5003
NODE_ENV=development
SERVICE_MODE=sandbox

MONGODB_URI=mongodb://127.0.0.1:27017/pingload
JWT_SECRET=pingload-local-dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Paystack TEST keys — https://dashboard.paystack.com/#/settings/developer
PAYSTACK_ENV=test
PAYSTACK_PUBLIC_KEY=pk_test_<your-paystack-test-public-key>
PAYSTACK_SECRET_KEY=sk_test_<your-paystack-test-secret-key>

# VTpass SANDBOX keys — https://vtpass.com
VTPASS_ENV=sandbox
VTPASS_API_KEY=<your-vtpass-sandbox-api-key>
VTPASS_PUBLIC_KEY=<your-vtpass-sandbox-public-key>
VTPASS_SECRET_KEY=<your-vtpass-sandbox-secret-key>

# Termii — leave as placeholder to log OTP to console
TERMII_API_KEY=dev-placeholder
TERMII_SENDER_ID=Pingload
TERMII_BASE_URL=https://api.ng.termii.com/api
TERMII_EMAIL_CONFIGURATION_ID=
TERMII_OTP_CHANNEL=auto

API_PUBLIC_URL=http://localhost:5003
FRONTEND_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:5174,http://localhost:8081

REFERRAL_BONUS=100
DEVELOPMENT_MODE=true
ENABLE_SERVICE_LOGS=true

ADMIN_EMAIL=admin@pingload.top
ADMIN_PASSWORD=admin123

SUPPORT_EMAIL=support@pingload.top
SUPPORT_WHATSAPP=2348000000000
