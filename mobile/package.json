    "@react-navigation/native-stack": "^7.2.0",
    "@tanstack/react-query": "^5.62.8",
    "axios": "^1.7.9",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.0",
    "expo-clipboard": "~8.0.0",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.0",
