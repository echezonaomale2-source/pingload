  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "node scripts/start-metro.js",
    "start:clear": "node scripts/start-metro.js --clear",
    "start:localhost": "expo start --localhost",
    "start:tunnel": "expo start --tunnel --clear",
