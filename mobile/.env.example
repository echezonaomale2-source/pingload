# =============================================================================
# Pingload Mobile — Environment Template (Expo)
# =============================================================================
# Copy to .env and fill before building for production.
# Expo reads EXPO_PUBLIC_* variables at build time.
# Never commit a filled .env file.
# =============================================================================

# Production API base URL (only used when EXPO_PUBLIC_USE_LIVE_API=true)
# EXPO_PUBLIC_USE_LIVE_API=true
# EXPO_PUBLIC_API_URL=https://pingload.top/api

# Local development (default) — backend on your PC, LAN IP auto-detected for physical devices
EXPO_PUBLIC_USE_LIVE_API=false
# EXPO_PUBLIC_DEV_HOST=192.168.1.100
# EXPO_PUBLIC_API_PORT=5003

# Tawk.to live chat — https://dashboard.tawk.to/
EXPO_PUBLIC_TAWK_PROPERTY_ID=6a38286a0f2eba1d56794e32
EXPO_PUBLIC_TAWK_WIDGET_ID=1jrllrok0

# Support channels shown in the app
EXPO_PUBLIC_SUPPORT_WHATSAPP=2348000000000
EXPO_PUBLIC_SUPPORT_EMAIL=support@pingload.top
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://pingload.top/privacy
EXPO_PUBLIC_TERMS_URL=https://pingload.top/terms
EXPO_PUBLIC_APP_DOMAIN=pingload.top

# Paystack public key is fetched from GET /wallet/payment-config at runtime.
# Do not embed Paystack secret keys in the mobile app.
